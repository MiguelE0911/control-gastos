<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<ScrollPane fitToWidth="true"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.miguel.gastos.controller.FormularioController"
            stylesheets="@../css/dark-theme.css"
            style="-fx-background-color: #1e1e2e;"
            prefWidth="440" prefHeight="500">
    <VBox spacing="20"
          style="-fx-padding: 24px; -fx-background-color: #1e1e2e;">

    <!-- Título -->
    <Label text="Nuevo Gasto"
           style="-fx-text-fill: #cdd6f4; -fx-font-size: 18px; -fx-font-weight: bold;"/>

    <!-- Tipo de gasto -->
    <VBox spacing="6">
        <Label text="Tipo de gasto" styleClass="form-label"/>
        <ComboBox fx:id="cmbTipo" prefWidth="372"
                  styleClass="form-field"
                  onAction="#onTipoSeleccionado"/>
    </VBox>

    <!-- Descripción -->
    <VBox spacing="6">
        <Label text="Descripción" styleClass="form-label"/>
        <TextField fx:id="txtDescripcion" styleClass="form-field"
                   promptText="Ej: Alquiler, Supermercado..."/>
    </VBox>

    <!-- Monto -->
    <VBox spacing="6">
        <Label text="Monto ($)" styleClass="form-label"/>
        <TextField fx:id="txtMonto" styleClass="form-field"
                   promptText="0.00"/>
    </VBox>

    <!-- Fecha -->
    <VBox spacing="6">
        <Label text="Fecha" styleClass="form-label"/>
        <DatePicker fx:id="dateFecha" prefWidth="372"
                    styleClass="form-field"/>
    </VBox>

    <!-- Panel dinámico según tipo -->
    <!-- GastoFijo: día de pago -->
    <VBox fx:id="panelFijo" spacing="6" managed="false" visible="false">
        <Label text="Día de pago (1-31)" styleClass="form-label"/>
        <TextField fx:id="txtDiaPago" styleClass="form-field"
                   promptText="Ej: 1"/>
    </VBox>

    <!-- GastoVariable: subcategoría -->
    <VBox fx:id="panelVariable" spacing="6" managed="false" visible="false">
        <Label text="Subcategoría" styleClass="form-label"/>
        <ComboBox fx:id="cmbSubcategoria" prefWidth="372"
                  styleClass="form-field"/>
    </VBox>

    <!-- GastoOcio: recurrente -->
    <VBox fx:id="panelOcio" spacing="6" managed="false" visible="false">
        <CheckBox fx:id="chkRecurrente" text="¿Es recurrente?"
                  style="-fx-text-fill: #cdd6f4;"/>
    </VBox>

    <!-- Botones -->
    <HBox spacing="12" alignment="CENTER_RIGHT" style="-fx-padding: 8px 0 0 0;">
        <Button text="Cancelar" onAction="#cancelar"
                style="-fx-background-color: #45475a; -fx-text-fill: #cdd6f4;
                       -fx-background-radius: 8px; -fx-padding: 8px 20px;
                       -fx-cursor: hand;"/>
        <Button text="Guardar" onAction="#guardar"
                styleClass="btn-primary"/>
    </HBox>

    </VBox>
</ScrollPane>