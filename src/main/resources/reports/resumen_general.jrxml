<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="resumen_general"
              pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20"
              topMargin="20" bottomMargin="20">

    <!-- Parámetros que recibe desde Java -->
    <parameter name="totalFijos"     class="java.lang.Double"/>
    <parameter name="totalVariables" class="java.lang.Double"/>
    <parameter name="totalOcio"      class="java.lang.Double"/>
    <parameter name="totalGeneral"   class="java.lang.Double"/>
    <parameter name="fechaReporte"   class="java.lang.String"/>

    <!-- Campos del DTO -->
    <field name="tipo"        class="java.lang.String"/>
    <field name="descripcion" class="java.lang.String"/>
    <field name="monto"       class="java.lang.Double"/>
    <field name="fecha"       class="java.lang.String"/>
    <field name="detalle"     class="java.lang.String"/>

    <!-- ENCABEZADO -->
    <title>
        <band height="120">
            <!-- Título -->
            <staticText>
                <reportElement x="0" y="0" width="555" height="30"
                               forecolor="#1e1e2e" backcolor="#89b4fa" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[Resumen General de Gastos]]></text>
            </staticText>

            <!-- Fecha del reporte -->
            <textField>
                <reportElement x="0" y="32" width="555" height="20"/>
                <textElement textAlignment="Center">
                    <font size="10" isItalic="true"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Generado el: " + $P{fechaReporte}]]>
                </textFieldExpression>
            </textField>

            <!-- Resumen por tipo -->
            <staticText>
                <reportElement x="0" y="60" width="130" height="20"
                               backcolor="#313244" forecolor="#89b4fa" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font isBold="true" size="9"/>
                </textElement>
                <text><![CDATA[Gastos Fijos]]></text>
            </staticText>
            <textField pattern="$#,##0.00">
                <reportElement x="130" y="60" width="100" height="20"/>
                <textElement textAlignment="Right">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{totalFijos}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="240" y="60" width="130" height="20"
                               backcolor="#313244" forecolor="#a6e3a1" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font isBold="true" size="9"/>
                </textElement>
                <text><![CDATA[Gastos Variables]]></text>
            </staticText>
            <textField pattern="$#,##0.00">
                <reportElement x="370" y="60" width="100" height="20"/>
                <textElement textAlignment="Right">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{totalVariables}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="85" width="130" height="20"
                               backcolor="#313244" forecolor="#fab387" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font isBold="true" size="9"/>
                </textElement>
                <text><![CDATA[Ocio]]></text>
            </staticText>
            <textField pattern="$#,##0.00">
                <reportElement x="130" y="85" width="100" height="20"/>
                <textElement textAlignment="Right">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{totalOcio}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="350" y="85" width="100" height="20"
                               backcolor="#1e1e2e" forecolor="#cdd6f4" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font isBold="true" size="9"/>
                </textElement>
                <text><![CDATA[TOTAL GENERAL]]></text>
            </staticText>
            <textField pattern="$#,##0.00">
                <reportElement x="450" y="85" width="105" height="20"
                               forecolor="#89b4fa"/>
                <textElement textAlignment="Right">
                    <font size="10" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{totalGeneral}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <!-- ENCABEZADO DE COLUMNAS -->
    <columnHeader>
        <band height="25">
            <staticText>
                <reportElement x="0"   y="0" width="80"  height="25"
                               backcolor="#313244" forecolor="#89b4fa" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font isBold="true" size="9"/>
                </textElement>
                <text><![CDATA[Tipo]]></text>
            </staticText>
            <staticText>
                <reportElement x="80"  y="0" width="180" height="25"
                               backcolor="#313244" forecolor="#89b4fa" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font isBold="true" size="9"/>
                </textElement>
                <text><![CDATA[Descripción]]></text>
            </staticText>
            <staticText>
                <reportElement x="260" y="0" width="90"  height="25"
                               backcolor="#313244" forecolor="#89b4fa" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font isBold="true" size="9"/>
                </textElement>
                <text><![CDATA[Monto]]></text>
            </staticText>
            <staticText>
                <reportElement x="350" y="0" width="90"  height="25"
                               backcolor="#313244" forecolor="#89b4fa" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font isBold="true" size="9"/>
                </textElement>
                <text><![CDATA[Fecha]]></text>
            </staticText>
            <staticText>
                <reportElement x="440" y="0" width="115" height="25"
                               backcolor="#313244" forecolor="#89b4fa" mode="Opaque"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font isBold="true" size="9"/>
                </textElement>
                <text><![CDATA[Detalle]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- DETALLE: se repite por cada fila -->
    <detail>
        <band height="20">
            <textField>
                <reportElement x="0"   y="0" width="80"  height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{tipo}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="80"  y="0" width="180" height="20"/>
                <textElement verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{descripcion}]]></textFieldExpression>
            </textField>
            <textField pattern="$#,##0.00">
                <reportElement x="260" y="0" width="90"  height="20"/>
                <textElement textAlignment="Right" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{monto}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="350" y="0" width="90"  height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{fecha}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="440" y="0" width="115" height="20"/>
                <textElement textAlignment="Center" verticalAlignment="Middle">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[$F{detalle}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <!-- PIE DE PÁGINA -->
    <pageFooter>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="555" height="20"/>
                <textElement textAlignment="Right">
                    <font size="8" isItalic="true"/>
                </textElement>
                <textFieldExpression>
                    <![CDATA["Página " + $V{PAGE_NUMBER}]]>
                </textFieldExpression>
            </textField>
        </band>
    </pageFooter>

</jasperReport>